{{define "content"}}
<hgroup>
    <h2>LiveTemplate Patterns</h2>
    <p>31 UI patterns demonstrating progressive complexity</p>
</hgroup>
{{range .Categories}}
<article>
    <h4>{{.Name}}</h4>
    {{range .Patterns}}
    <p>
        {{if .Implemented}}<a href="{{basePath}}{{.RelPath}}">{{.Name}}</a>{{else}}<small>{{.Name}}</small>{{end}}
        — <small>{{.Description}}</small>
    </p>
    {{end}}
</article>
{{end}}
{{end}}
