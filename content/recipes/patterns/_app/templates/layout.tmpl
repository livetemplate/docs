<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="light dark">
    <title>{{if .Title}}{{.Title}} — {{end}}LiveTemplate Patterns</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
    {{if .lvt.DevMode}}
    <link rel="stylesheet" href="{{basePath}}/livetemplate.css">
    <script defer src="{{basePath}}/livetemplate-client.js"></script>
    {{else}}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@livetemplate/client@latest/livetemplate.css">
    <script defer src="https://cdn.jsdelivr.net/npm/@livetemplate/client@latest/dist/livetemplate-client.browser.js"></script>
    {{end}}
</head>
<body>
    <main class="container">
        <nav>
            <ul><li><a href="{{basePath}}/"><strong>Patterns</strong></a></li></ul>
            {{if .Category}}<ul><li><small>{{.Category}}</small></li></ul>{{end}}
        </nav>
        {{template "content" .}}
    </main>
</body>
</html>
