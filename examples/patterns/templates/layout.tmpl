<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="light dark">
    <title>{{if .Title}}{{.Title}} — {{end}}LiveTemplate UI Pattern Recipes</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
    <link rel="stylesheet" href="{{lvtClientStyleURL}}">
    <script defer src="{{lvtClientScriptURL}}"></script>
</head>
<body>
    <main class="container">
        <nav>
            <ul><li><a href="{{basePath}}/"><strong>UI Pattern Recipes</strong></a></li></ul>
            {{if .Category}}<ul><li><small>{{.Category}}</small></li></ul>{{end}}
        </nav>
        {{template "content" .}}
    </main>
</body>
</html>
