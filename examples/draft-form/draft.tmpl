<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Draft or publish</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
    <link rel="stylesheet" href="{{lvtClientStyleURL}}">
    <script defer src="{{lvtClientScriptURL}}"></script>
</head>
<body>
    <main class="container">
        <h1>Draft or publish</h1>
        {{if .Status}}<p data-status="{{.Status}}">Saved as <strong>{{.Status}}</strong>: &ldquo;{{.Title}}&rdquo;</p>{{end}}
        <form method="POST">
            <input name="title" placeholder="Post title" required {{.lvt.AriaInvalid "title"}}>
            {{.lvt.ErrorTag "title"}}
            <button name="publish">Publish</button>
            <button name="save-draft" formnovalidate class="secondary">Save draft</button>
        </form>
    </main>
</body>
</html>
