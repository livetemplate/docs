<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="light dark">
    <title>Auto Upload (SSR) — LiveTemplate</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
    <link rel="stylesheet" href="{{lvtClientStyleURL}}">
    <script defer src="{{lvtClientScriptURL}}"></script>
</head>
<body>
    <main class="container">
        <article>
            <header>
                <hgroup>
                    <h1>Auto Upload on Select</h1>
                    <p>The file input below is server-rendered and uploads as soon as you pick a file.</p>
                </hgroup>
            </header>

            <label for="avatar">
                Avatar
                <input type="file"
                       id="avatar"
                       lvt-upload="avatar"
                       accept="image/jpeg,image/png,image/gif">
            </label>

            {{range .lvt.Uploads "avatar"}}
                <div data-key="{{.ID}}">
                    <small><strong>{{.ClientName}}</strong> — {{.Progress}}%</small>
                    <progress value="{{.Progress}}" max="100"></progress>
                    {{if .Error}}
                        <del style="display:block;text-decoration:none">{{.Error}}</del>
                    {{else if .Done}}
                        <ins id="upload-done" style="display:block;text-decoration:none">Upload complete!</ins>
                    {{else}}
                        <small>Uploading...</small>
                    {{end}}
                </div>
            {{end}}

            {{if .lvt.HasUploadError "avatar"}}
                <del style="display:block;text-decoration:none">{{.lvt.UploadError "avatar"}}</del>
            {{end}}

            <footer>
                <small>Powered by <a href="https://github.com/livetemplate/livetemplate" target="_blank">LiveTemplate</a></small>
            </footer>
        </article>
    </main>
</body>
</html>
