<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Hello</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@livetemplate/client@latest/livetemplate.css">
    <script defer src="https://cdn.jsdelivr.net/npm/@livetemplate/client@latest/dist/livetemplate-client.browser.js"></script>
</head>
<body>
    <main class="container">
        <h1>Hello, {{.Name}}</h1>
        <form method="POST">
            <input name="name" placeholder="Your name" required>
            <button name="greet" lvt-el:setAttr:on:pending="aria-busy:true" lvt-el:setAttr:on:done="aria-busy:false">Say hi</button>
        </form>
        {{if .Count}}<small class="greet-count">greeted {{.Count}}×</small>{{end}}
    </main>
</body>
</html>
